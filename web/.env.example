DATABASE_URL="file:./prisma/dev.db"

# Clerk auth — get these from clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# S3 / Cloudflare R2 image storage
S3_BUCKET=
S3_REGION=auto
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  # optional, for R2 or custom S3-compatible endpoint
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Public base URL used to construct image URLs in the frontend (no trailing slash)
NEXT_PUBLIC_S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
