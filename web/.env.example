DATABASE_URL="file:./prisma/dev.db"

# Clerk auth — get these from clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# S3 / R2 media storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=              # optional — set for Cloudflare R2 or other S3-compatible
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
NEXT_PUBLIC_S3_PUBLIC_URL= # public URL prefix for serving images (e.g. https://cdn.example.com)
